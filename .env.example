# Prunus LLM API 配置
# 将此文件复制为 .env.local 并填入你的真实配置
# 注意：.env.local 文件不会被提交到 Git，保护你的 API Key

# LLM API Base URL（不带尾部斜杠）
# 例如：https://api.openai.com/v1 或 https://api.lkeap.cloud.tencent.com/coding/v3
LLM_BASE_URL=https://api.openai.com/v1

# LLM API Key
LLM_API_KEY=sk-your-api-key-here

# 默认模型
LLM_MODEL=gpt-3.5-turbo